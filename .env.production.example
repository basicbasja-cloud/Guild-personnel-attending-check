# Example `.env.production` (DO NOT commit real secrets)
# Copy this to `.env.production` locally or set the values as GitHub repository secrets.
# Secrets required by the Actions workflow: `VITE_SUPABASE_URL`, `VITE_SUPABASE_ANON_KEY`

VITE_SUPABASE_URL=https://your-supabase-url.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_anon_key_here
VITE_ENABLE_GOOGLE_LOGIN=true

# Replace values above with your production values or create repository secrets
# named `VITE_SUPABASE_URL` and `VITE_SUPABASE_ANON_KEY` in GitHub settings.
